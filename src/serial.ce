#hint implicit-void-function
module Template.Serial;


// c passed as B0
literal forceinline expose noreturn fun WriteChar(char c) {
    OUTPRT.S #1, #0x00001234, B0 // On BSEMU, port 0x1234 is STDOUT
}

expose fun WriteString(constant char* s) {
    char* local = s;
    while (*local)
        WriteChar(*local++);
}

expose fun Write(char* s) {
    WriteString(s);
}